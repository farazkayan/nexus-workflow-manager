{
  "manifest_version": 3,
  "name": "Nexus",
  "version": "2.0",
  "description": "Launch and manage your Nexus workflows from Chrome.",
  "permissions": ["activeTab", "tabs", "storage", "contextMenus"],
  "host_permissions": ["http://127.0.0.1:57832/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
